{
  "name": "mcp-prosuite-email",
  "version": "1.0.8",
  "description": "郵件管理發送的MCP工具",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts src/sse-server.ts src/tools/mail.ts src/tools/mail-service.ts src/tools/process-manager.ts --bundle=false --format=esm --platform=node --outdir=dist --outbase=src --sourcemap",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "start:sse": "node dist/sse-server.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "dev:sse": "ts-node-dev --respawn src/sse-server.ts",
    "test": "jest"
  },
  "keywords": [
    "mcp",
    "mail",
    "email",
    "smtp",
    "imap",
    "tools"
  ],
  "author": "kino_lian",
  "license": "UNLICENSED",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/express": "^5.0.3",
    "@types/node": "^20.0.0",
    "dotenv": "^16.0.3",
    "express": "^5.1.0",
    "imap": "^0.8.17",
    "mailparser": "^3.9.3",
    "nodemailer": "^7.0.13",
    "typescript": "^5.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/imap": "^0.8.40",
    "@types/mailparser": "^3.4.0",
    "@types/nodemailer": "^6.4.9",
    "esbuild": "^0.27.3",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0"
  },
  "overrides": {
    "minimatch": "^10.2.4",
    "qs": "^6.15.0",
    "tar": "^7.5.10",
    "glob": "^10.5.0",
    "body-parser": "^2.2.2",
    "diff": "^8.0.3"
  }
}
